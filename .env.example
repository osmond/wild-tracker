# ─── API Keys ────────────────────────────────────────────────────────────────
# SportRadar NHL API  (https://developer.sportradar.com)
SPORTRADAR_API_KEY=your_sportradar_api_key_here

# The Odds API        (https://the-odds-api.com)
ODDS_API_KEY=your_odds_api_key_here

# ─── Email Alerts (optional) ─────────────────────────────────────────────────
# Address that will receive sharp-move and settle notifications
ALERT_EMAIL=you@example.com

# Gmail account used as the sender — must have 2FA + an App Password configured
# https://support.google.com/accounts/answer/185833
GMAIL_USER=yourbot@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# ─── Optional ────────────────────────────────────────────────────────────────
# Port the Express server listens on (default: 3000)
PORT=3000

# Absolute path to the SQLite database file (default: ./data/wild.db)
# DB_PATH=/absolute/path/to/wild.db

# Timezone for cron jobs (default: America/Chicago)
# CRON_TZ=America/Chicago
